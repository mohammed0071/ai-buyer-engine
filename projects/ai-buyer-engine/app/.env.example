# ============================================================
# AI Buyer Engine - Environment Variables
# ============================================================
# Copy this to .env.local and fill in real values
# The app works in demo mode with placeholder values

# ---- Supabase ----
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Stripe ----
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret from: Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- GoHighLevel (GHL) ----
# Get API key from: GHL Settings → Business Profile → API Key
# Location ID from: GHL Settings → Business Profile
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_CALENDAR_ID=
GHL_PIPELINE_ID=

# ---- X/Twitter API ----
# Get these from: https://developer.x.com → Dashboard → Projects & Apps
# Requires at least Basic tier ($100/mo)
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ---- App Configuration ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AI Buyer Engine
