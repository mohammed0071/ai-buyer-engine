<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
--sage:#6B7F5E;--sage-light:#95A888;--sage-dark:#3D5230;
--gold:#C49B2A;--gold-light:#D4B44E;--gold-dark:#9A7A1E;
--cream:#FAF6F0;--cream-dark:#F0E8D8;
--earth:#6B5B4E;--earth-light:#8B7B6E;
--text:#2E2A25;--text-light:#5C5047;
--white:#FFFFFF;
--cta:#D4763A;--cta-dark:#B8612E;
--warm-accent:#C47A5A;
}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:'Playfair Display','Georgia','Times New Roman',serif;color:var(--text);background:var(--cream);line-height:1.7;-webkit-font-smoothing:antialiased;overflow-x:hidden}
img{max-width:100%;display:block}
a{color:var(--sage-dark);text-decoration:none}
h1,h2,h3,h4{line-height:1.2;font-weight:700;font-family:'Playfair Display','Georgia','Times New Roman',serif}
.container{max-width:1100px;margin:0 auto;padding:0 1.25rem}
.sans{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}

/* Buttons */
.btn{display:inline-block;padding:1rem 2.2rem;border-radius:50px;font-size:1rem;font-weight:600;cursor:pointer;transition:all .35s cubic-bezier(.4,0,.2,1);border:none;text-align:center;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;letter-spacing:.02em}
.btn-primary{background:linear-gradient(135deg,var(--cta),var(--cta-dark));color:var(--white);box-shadow:0 4px 20px rgba(212,118,58,.35);position:relative;overflow:hidden}
.btn-primary::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);transition:left .5s}
.btn-primary:hover{transform:translateY(-3px) scale(1.03);box-shadow:0 8px 35px rgba(212,118,58,.55)}
.btn-primary:hover::before{left:100%}
.btn-secondary{background:transparent;color:var(--sage-dark);border:2px solid var(--sage);padding:.9rem 2.2rem;border-radius:50px}
.btn-secondary:hover{background:var(--sage);color:var(--white);transform:translateY(-2px) scale(1.02);box-shadow:0 6px 20px rgba(61,82,48,.35)}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:var(--white);box-shadow:0 4px 15px rgba(196,155,42,.3)}
.btn-gold:hover{transform:translateY(-2px) scale(1.02);box-shadow:0 8px 25px rgba(196,155,42,.45)}

/* Pulse glow for hero CTA */
.btn-glow{animation:pulseGlow 2.5s ease-in-out infinite}
@keyframes pulseGlow{0%,100%{box-shadow:0 4px 20px rgba(212,118,58,.35)}50%{box-shadow:0 4px 35px rgba(212,118,58,.6),0 0 60px rgba(212,118,58,.15)}}
.btn-glow:hover{animation:none}

/* Top bar */
.top-bar{background:var(--sage-dark);color:var(--white);padding:.45rem 0;font-size:.8rem}
.top-bar .container{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem}
.top-bar a{color:var(--white);font-weight:500}
.top-bar a:hover{color:var(--gold-light)}
.top-bar-left{display:flex;gap:1.5rem;align-items:center}
.top-bar-right{display:flex;gap:1.5rem;align-items:center}

/* Nav */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(250,246,240,.95);backdrop-filter:blur(12px);border-bottom:1px solid rgba(0,0,0,.04);padding:.75rem 0;transition:all .3s}
nav.scrolled{box-shadow:0 2px 20px rgba(0,0,0,.08)}
nav .container{display:flex;justify-content:space-between;align-items:center}
.logo{font-size:1.3rem;font-weight:700;color:var(--sage-dark);letter-spacing:.03em;display:flex;align-items:center;gap:.5rem;font-family:'Playfair Display',Georgia,serif}
.logo span{color:var(--gold)}
.logo-img{width:44px;height:auto;object-fit:contain}.logo-img-full{height:52px;width:auto;max-width:280px;object-fit:contain}
.nav-links{display:flex;gap:1rem;align-items:center;list-style:none}
.nav-links a{color:var(--text-light);font-size:.82rem;font-weight:500;transition:color .2s;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
.nav-links a:hover{color:var(--sage-dark)}
.nav-cta{background:linear-gradient(135deg,var(--cta),var(--cta-dark))!important;color:var(--white)!important;padding:.55rem 1.3rem!important;border-radius:50px;font-weight:600;transition:all .3s!important}
.nav-cta:hover{box-shadow:0 4px 15px rgba(212,118,58,.4);transform:translateY(-1px)}
.nav-contact{display:flex;flex-direction:column;align-items:flex-end;gap:.15rem;font-family:-apple-system,sans-serif;font-size:.8rem;margin-left:1rem}
.nav-contact a{color:var(--text);font-weight:600;font-size:.85rem}
.menu-toggle{display:none;background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--text)}

/* SVG Dividers */
.divider-wave{width:100%;line-height:0;overflow:hidden}
.divider-wave svg{display:block;width:100%;height:auto}
.divider-wave.flip{transform:scaleY(-1)}

/* Hero */
.hero{padding:0;min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:
  radial-gradient(ellipse 70% 60% at 20% 30%,rgba(61,82,48,.18),transparent),
  radial-gradient(ellipse 50% 50% at 80% 20%,rgba(196,155,42,.12),transparent),
  radial-gradient(ellipse 60% 60% at 50% 90%,rgba(196,122,90,.08),transparent),
  linear-gradient(165deg,#2e3a28 0%,#3d5230 15%,#4a6238 30%,#5c7548 45%,var(--sage) 60%,var(--gold-dark) 80%,var(--gold) 100%);
  z-index:0}
.hero::after{content:'';position:absolute;inset:0;background:
  radial-gradient(ellipse 80% 70% at 50% 50%,rgba(250,246,240,.82),rgba(250,246,240,.5) 60%,rgba(250,246,240,.2) 80%);
  z-index:0}
.hero-particles{position:absolute;inset:0;z-index:1;pointer-events:none;overflow:hidden}
.hero-particles span{position:absolute;display:block;border-radius:50%;animation:float-up linear infinite}
.hero-particles span:nth-child(1){width:8px;height:8px;background:var(--gold);left:10%;opacity:.25;animation-duration:18s;animation-delay:0s}
.hero-particles span:nth-child(2){width:5px;height:5px;background:var(--sage-light);left:25%;opacity:.2;animation-duration:22s;animation-delay:3s}
.hero-particles span:nth-child(3){width:12px;height:12px;background:var(--gold-light);left:45%;opacity:.15;animation-duration:16s;animation-delay:1s}
.hero-particles span:nth-child(4){width:6px;height:6px;background:var(--sage);left:65%;opacity:.22;animation-duration:20s;animation-delay:5s}
.hero-particles span:nth-child(5){width:4px;height:4px;background:var(--gold);left:80%;opacity:.3;animation-duration:24s;animation-delay:2s}
.hero-particles span:nth-child(6){width:10px;height:10px;background:var(--warm-accent);left:90%;opacity:.12;animation-duration:19s;animation-delay:4s}
.hero-particles span:nth-child(7){width:7px;height:7px;background:var(--gold-dark);left:15%;opacity:.18;animation-duration:21s;animation-delay:7s}
.hero-particles span:nth-child(8){width:3px;height:3px;background:var(--sage-light);left:55%;opacity:.28;animation-duration:17s;animation-delay:6s}
.hero-particles span:nth-child(9){width:9px;height:9px;background:var(--gold);left:35%;opacity:.1;animation-duration:25s;animation-delay:9s}
.hero-particles span:nth-child(10){width:5px;height:5px;background:var(--warm-accent);left:72%;opacity:.2;animation-duration:20s;animation-delay:8s}
@keyframes float-up{0%{bottom:-10%;opacity:0;transform:translateX(0) scale(.8)}10%{opacity:var(--particle-opacity,.2)}50%{transform:translateX(20px) scale(1)}80%{opacity:calc(var(--particle-opacity,.2) * .6)}100%{bottom:110%;opacity:0;transform:translateX(-15px) scale(.9)}}

.hero .container{position:relative;z-index:2;text-align:center}
.hero-badge{display:inline-block;background:rgba(250,246,240,.6);border:1px solid rgba(196,155,42,.3);border-radius:50px;padding:.5rem 1.4rem;font-size:.8rem;letter-spacing:.14em;text-transform:uppercase;color:var(--sage-dark);font-weight:700;margin-bottom:1.5rem;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;animation:fadeDown .8s ease .2s both;backdrop-filter:blur(8px)}
.hero-stats{display:flex;justify-content:center;gap:2.5rem;flex-wrap:wrap;margin-bottom:2rem;animation:fadeDown .8s ease .3s both}
.hero-stat{font-family:-apple-system,sans-serif;font-size:.9rem;color:var(--text-light)}
.hero-stat strong{color:var(--gold-dark);font-size:1.2rem}
.hero h1{font-size:clamp(2.8rem,6.5vw,4.5rem);color:var(--text);margin-bottom:1.25rem;max-width:850px;margin-left:auto;margin-right:auto;animation:fadeDown .8s ease .4s both;font-weight:800;letter-spacing:-.02em;text-shadow:0 1px 3px rgba(250,246,240,.6)}
.hero h1 em{font-style:italic;background:linear-gradient(135deg,var(--sage-dark),var(--sage));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;padding-right:.15em;margin-right:-.15em}
.hero p.hero-desc{font-size:clamp(1.1rem,2.5vw,1.3rem);color:var(--text);max-width:620px;margin:0 auto 2.5rem;line-height:1.8;animation:fadeDown .8s ease .6s both;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;text-shadow:0 1px 2px rgba(250,246,240,.5)}
.hero-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;animation:fadeDown .8s ease .8s both}
.hero-note{margin-top:1.5rem;font-size:.85rem;color:var(--text-light);animation:fadeDown .8s ease 1s both;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;text-shadow:0 1px 2px rgba(250,246,240,.5)}
@keyframes fadeDown{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}

/* Scroll reveal - multiple types */
.reveal{opacity:0;transform:translateY(30px);transition:all .7s cubic-bezier(.4,0,.2,1)}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-left{opacity:0;transform:translateX(-40px);transition:all .7s cubic-bezier(.4,0,.2,1)}
.reveal-left.visible{opacity:1;transform:translateX(0)}
.reveal-right{opacity:0;transform:translateX(40px);transition:all .7s cubic-bezier(.4,0,.2,1)}
.reveal-right.visible{opacity:1;transform:translateX(0)}
.reveal-scale{opacity:0;transform:scale(.92);transition:all .7s cubic-bezier(.4,0,.2,1)}
.reveal-scale.visible{opacity:1;transform:scale(1)}

/* Stagger children */
.stagger-children .reveal:nth-child(2){transition-delay:.1s}
.stagger-children .reveal:nth-child(3){transition-delay:.2s}
.stagger-children .reveal:nth-child(4){transition-delay:.3s}
.stagger-children .reveal:nth-child(5){transition-delay:.4s}
.stagger-children .reveal:nth-child(6){transition-delay:.5s}

/* Section base */
section{padding:5.5rem 0}
.section-label{text-transform:uppercase;font-size:.75rem;letter-spacing:.22em;color:var(--gold);font-weight:700;margin-bottom:.75rem;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
.section-title{font-size:clamp(2rem,4vw,3rem);margin-bottom:1rem;font-weight:800;letter-spacing:-.01em}
.section-sub{color:var(--text-light);max-width:600px;margin:0 auto 3rem;font-size:1.05rem;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
.text-center{text-align:center}

/* Background pattern for alternate sections */
.bg-pattern{position:relative}
.bg-pattern::after{content:'';position:absolute;inset:0;background-image:radial-gradient(circle at 1px 1px,rgba(107,127,94,.04) 1px,transparent 0);background-size:32px 32px;pointer-events:none;z-index:0}
.bg-pattern>.container{position:relative;z-index:1}

/* Trust bar */
.trust-bar{text-align:center;padding:1.5rem 0;background:var(--white);border-top:1px solid rgba(0,0,0,.04);border-bottom:1px solid rgba(0,0,0,.04)}
.trust-items{display:flex;justify-content:center;gap:2rem;flex-wrap:wrap;font-family:-apple-system,sans-serif;font-size:.85rem;color:var(--earth-light)}
.trust-items span{display:flex;align-items:center;gap:.4rem}
.trust-items strong{color:var(--gold-dark)}

/* Outcomes strip */
.outcomes{background:linear-gradient(135deg,var(--sage-dark) 0%,#2e3a28 40%,#3d4f30 70%,var(--sage-dark) 100%);color:var(--white);padding:4.5rem 0;position:relative;overflow:hidden}
.outcomes::before{content:'';position:absolute;top:-50%;left:-20%;width:60%;height:200%;background:radial-gradient(circle,rgba(196,155,42,.06),transparent 70%);pointer-events:none}
.outcomes::after{content:'';position:absolute;bottom:-30%;right:-10%;width:50%;height:150%;background:radial-gradient(circle,rgba(196,155,42,.04),transparent 60%);pointer-events:none}
.outcomes-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2.5rem;text-align:center}
.outcome-item{transition:transform .3s}
.outcome-item:hover{transform:translateY(-8px)}
.outcome-icon{font-size:2.2rem;margin-bottom:.75rem;display:block}
.outcomes-grid h3{font-size:1.15rem;font-weight:700;margin-bottom:.4rem;font-family:'Playfair Display',Georgia,serif}
.outcomes-grid p{font-size:.9rem;opacity:.8;font-family:-apple-system,sans-serif}

/* ICP tabs */
.icp-section{background:var(--white)}
.icp-tabs{display:flex;justify-content:center;gap:.75rem;flex-wrap:wrap;margin-bottom:2.5rem}
.icp-tab{padding:.65rem 1.5rem;border-radius:50px;border:2px solid var(--sage-light);background:rgba(107,127,94,.08);color:var(--text-light);cursor:pointer;font-family:-apple-system,sans-serif;font-size:.9rem;font-weight:500;transition:all .3s;position:relative}
.icp-tab::after{content:'';display:inline-block;margin-left:.4rem;width:0;height:0;border-left:4px solid transparent;border-right:4px solid transparent;border-top:5px solid currentColor;vertical-align:middle;opacity:.5;transition:opacity .3s}
.icp-tab.active{background:var(--sage-dark);color:var(--white);border-color:var(--sage-dark);box-shadow:0 4px 15px rgba(61,82,48,.25)}
.icp-tab.active::after{border-top-color:var(--white);opacity:1}
.icp-tab:hover:not(.active){border-color:var(--sage);background:rgba(107,127,94,.15);color:var(--text)}
.icp-tab-hint{text-align:center;font-size:.82rem;color:var(--text-light);margin-bottom:1.5rem;opacity:.7;font-style:italic}
.icp-content{display:none;max-width:700px;margin:0 auto;text-align:center}
.icp-content.active{display:block;animation:fadeIn .4s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.icp-content h3{font-size:1.5rem;margin-bottom:1rem;color:var(--text)}
.icp-content p{color:var(--text-light);font-size:1.05rem;line-height:1.8;margin-bottom:1.5rem;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
.icp-content .btn{margin-top:.5rem}

/* Services */
.services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem}
.service-card{background:var(--white);border-radius:16px;padding:2.2rem 1.8rem;border:1px solid rgba(0,0,0,.06);transition:all .4s cubic-bezier(.4,0,.2,1);position:relative;overflow:hidden}
.service-card.featured{border:2px solid transparent;background-image:linear-gradient(var(--white),var(--white)),linear-gradient(135deg,var(--cta),var(--gold),var(--cta));background-origin:border-box;background-clip:padding-box,border-box;box-shadow:0 4px 20px rgba(212,118,58,.12),0 0 40px rgba(212,118,58,.06)}
.service-card.featured .service-badge{position:absolute;top:1rem;right:1rem;background:linear-gradient(135deg,var(--cta),var(--cta-dark));color:var(--white);font-size:.7rem;padding:.3rem .85rem;border-radius:20px;font-family:-apple-system,sans-serif;font-weight:600;text-transform:uppercase;letter-spacing:.05em}
.service-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--gold),var(--sage),var(--gold));transform:scaleX(0);transform-origin:left;transition:transform .4s}
.service-card:hover{box-shadow:0 16px 50px rgba(0,0,0,.1);transform:translateY(-8px)}
.service-card.featured:hover{box-shadow:0 16px 50px rgba(212,118,58,.18),0 0 60px rgba(212,118,58,.08)}
.service-card:hover::before{transform:scaleX(1)}
.service-icon{width:54px;height:54px;background:linear-gradient(135deg,rgba(196,155,42,.1),rgba(107,127,94,.1));border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:1.25rem;transition:transform .3s}
.service-card:hover .service-icon{transform:scale(1.1)}
.service-card h3{font-size:1.2rem;margin-bottom:.6rem;color:var(--text)}
.service-card p{color:var(--text-light);font-size:.9rem;margin-bottom:1.25rem;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;line-height:1.7}
.service-card .service-meta{font-size:.8rem;color:var(--earth-light);font-family:-apple-system,sans-serif;margin-bottom:1rem;display:flex;gap:1rem}
.service-card a.service-link{color:var(--cta-dark);font-weight:600;font-size:.9rem;transition:all .2s;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;display:inline-flex;align-items:center;gap:.3rem}
.service-card a.service-link:hover{color:var(--cta);gap:.5rem}

/* Testimonials */
.testimonials{background:var(--cream-dark);position:relative;overflow:hidden}
.testimonials::before{content:'\201C';position:absolute;top:1rem;left:50%;transform:translateX(-50%);font-size:20rem;color:rgba(196,155,42,.1);font-family:'Playfair Display',Georgia,serif;pointer-events:none;line-height:1;z-index:0}
.testimonials::after{content:'';position:absolute;inset:0;background-image:
  radial-gradient(ellipse 100% 100% at 0% 100%,rgba(196,155,42,.04),transparent 50%),
  radial-gradient(ellipse 80% 80% at 100% 0%,rgba(107,127,94,.04),transparent 50%);
pointer-events:none}
.testimonials>.container{position:relative;z-index:1}
.test-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2rem;position:relative;z-index:1}
.test-card{background:var(--white);border-radius:16px;padding:2.2rem;border:1px solid rgba(0,0,0,.04);transition:all .4s cubic-bezier(.4,0,.2,1);position:relative}
.test-card::before{content:'';position:absolute;top:0;left:1.5rem;right:1.5rem;height:3px;background:linear-gradient(90deg,var(--gold),var(--gold-light),var(--gold));border-radius:3px 3px 0 0;opacity:0;transition:opacity .3s}
.test-card:hover{box-shadow:0 12px 40px rgba(0,0,0,.08);transform:translateY(-5px)}
.test-card:hover::before{opacity:1}
.test-card .stars{color:var(--gold);margin-bottom:.75rem;font-size:1.15rem;letter-spacing:2px}
.test-card blockquote{font-size:1rem;color:var(--text);line-height:1.8;margin-bottom:1rem;font-family:'Playfair Display',Georgia,serif;font-style:italic}
.test-card cite{font-size:.8rem;color:var(--text-light);font-style:normal;font-weight:600;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
.test-card .review-source{display:inline-block;background:rgba(66,133,244,.08);color:#4285f4;font-size:.65rem;padding:.15rem .5rem;border-radius:12px;margin-left:.4rem;font-weight:500;font-family:-apple-system,sans-serif}
.google-badge{text-align:center;margin-top:2rem;font-family:-apple-system,sans-serif}
.google-badge a{display:inline-flex;align-items:center;gap:.5rem;background:var(--white);padding:.75rem 1.5rem;border-radius:50px;font-size:.9rem;font-weight:600;color:var(--text);border:1px solid rgba(0,0,0,.08);transition:all .3s}
.google-badge a:hover{box-shadow:0 6px 20px rgba(0,0,0,.1);transform:translateY(-3px)}

/* Journey */
.journey-section{background:var(--white)}
.journey-steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:3rem;margin-top:3rem;position:relative}
.journey-steps::before{content:'';position:absolute;top:28px;left:calc(16.66% + 20px);right:calc(16.66% + 20px);height:2px;background:linear-gradient(90deg,var(--gold),var(--sage),var(--gold));opacity:.25;display:none}
@media(min-width:769px){.journey-steps::before{display:block}}
.step{text-align:center;position:relative}
.step-num{width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:var(--white);display:inline-flex;align-items:center;justify-content:center;font-weight:700;font-size:1.2rem;margin-bottom:1.25rem;box-shadow:0 6px 20px rgba(196,155,42,.35);position:relative;z-index:1;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;transition:transform .3s,box-shadow .3s}
.step:hover .step-num{transform:scale(1.1);box-shadow:0 8px 30px rgba(196,155,42,.45)}
.step h3{font-size:1.2rem;margin-bottom:.6rem}
.step p{color:var(--text-light);font-size:.95rem;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}

/* About */
.about{background:var(--cream);position:relative}
.about::before{content:'';position:absolute;top:0;right:0;width:40%;height:100%;background:radial-gradient(ellipse at right,rgba(196,155,42,.06),transparent 70%);pointer-events:none}
.about-inner{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.about-text h2{font-size:clamp(1.8rem,3.2vw,2.5rem);margin-bottom:1.25rem;font-weight:800}
.about-text p{color:var(--text-light);margin-bottom:1rem;font-size:.95rem;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;line-height:1.8}
.about-creds{display:flex;flex-wrap:wrap;gap:1rem;margin:1.5rem 0}
.cred-item{display:flex;align-items:center;gap:.4rem;background:var(--white);padding:.5rem .95rem;border-radius:50px;font-size:.8rem;font-family:-apple-system,sans-serif;color:var(--text-light);border:1px solid rgba(0,0,0,.06);transition:all .3s}
.cred-item:hover{border-color:var(--gold-light);box-shadow:0 2px 10px rgba(196,155,42,.12)}
.cred-item strong{color:var(--text)}
.about-img{background:linear-gradient(135deg,var(--cream-dark),#e0d8c8);border-radius:20px;aspect-ratio:4/5;display:flex;align-items:center;justify-content:center;color:var(--earth-light);font-size:.85rem;text-align:center;padding:2rem;box-shadow:0 20px 60px rgba(0,0,0,.08);position:relative;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
.about-img::before{content:'';position:absolute;inset:-3px;border-radius:23px;background:linear-gradient(135deg,var(--gold),var(--sage),var(--gold-light),var(--sage-dark));z-index:-1;opacity:.4}

/* FAQ */
.faq-section{background:var(--white)}
.faq-list{max-width:720px;margin:0 auto}
.faq-item{border-bottom:1px solid rgba(0,0,0,.06);padding:1.5rem 0}
.faq-q{font-size:1.05rem;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:1rem;transition:color .2s}
.faq-q:hover{color:var(--sage-dark)}
.faq-q::after{content:'+';font-size:1.5rem;color:var(--gold);transition:transform .3s;flex-shrink:0;width:30px;height:30px;border-radius:50%;background:rgba(196,155,42,.08);display:flex;align-items:center;justify-content:center;font-weight:300}
.faq-item.open .faq-q::after{transform:rotate(45deg);background:rgba(196,155,42,.15)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease;color:var(--text-light);font-size:.95rem;line-height:1.8;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
.faq-item.open .faq-a{max-height:300px;padding-top:1rem}

/* Contact / Booking form */
.booking-section{background:var(--cream-dark)}
.booking-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start}
.booking-form{background:var(--white);border-radius:16px;padding:2.5rem;box-shadow:0 8px 35px rgba(0,0,0,.06)}
.booking-form h3{font-size:1.5rem;margin-bottom:.5rem}
.booking-form p.form-sub{color:var(--text-light);font-size:.9rem;margin-bottom:1.5rem;font-family:-apple-system,sans-serif}
.form-group{margin-bottom:1.25rem}
.form-group label{display:block;font-size:.85rem;font-weight:600;margin-bottom:.4rem;color:var(--text);font-family:-apple-system,sans-serif}
.form-group input,.form-group select,.form-group textarea{width:100%;padding:.75rem 1rem;border:1px solid rgba(0,0,0,.1);border-radius:10px;font-size:.95rem;font-family:-apple-system,sans-serif;background:var(--cream);transition:all .3s}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{outline:none;border-color:var(--sage);box-shadow:0 0 0 3px rgba(107,127,94,.1)}
.form-group textarea{resize:vertical;min-height:80px}
.booking-info h3{font-size:1.5rem;margin-bottom:1rem}
.booking-info-item{display:flex;align-items:flex-start;gap:1rem;margin-bottom:1.5rem;font-family:-apple-system,sans-serif}
.booking-info-icon{width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,var(--white),var(--cream));display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;box-shadow:0 3px 12px rgba(0,0,0,.06);transition:transform .3s}
.booking-info-item:hover .booking-info-icon{transform:scale(1.08)}
.booking-info-item h4{font-size:1rem;margin-bottom:.2rem}
.booking-info-item p{font-size:.9rem;color:var(--text-light)}
.booking-info-item a{color:var(--sage-dark);font-weight:600}

/* Map */
.map-section{padding:0}
.map-section iframe{width:100%;height:350px;border:0;display:block}

/* CTA band */
.cta-band{background:linear-gradient(135deg,rgba(46,58,40,.88),rgba(61,82,48,.85)),url('images/forest-bg.jpg') center/cover no-repeat;color:var(--white);text-align:center;padding:6rem 0;position:relative;overflow:hidden}
.cta-band::before{content:'';position:absolute;inset:0;background:
  radial-gradient(circle at 20% 50%,rgba(196,155,42,.12),transparent 50%),
  radial-gradient(circle at 80% 50%,rgba(196,155,42,.08),transparent 50%),
  radial-gradient(circle at 50% 0%,rgba(255,255,255,.04),transparent 40%);
  pointer-events:none}
.cta-band::after{content:'';position:absolute;inset:0;background-image:radial-gradient(circle at 1px 1px,rgba(255,255,255,.02) 1px,transparent 0);background-size:40px 40px;pointer-events:none;animation:driftPattern 30s linear infinite}
@keyframes driftPattern{0%{background-position:0 0}100%{background-position:40px 40px}}
.cta-band .container{position:relative;z-index:1}
.cta-band h2{font-size:clamp(2rem,4.5vw,3.2rem);margin-bottom:1.25rem;font-weight:800}
.cta-band p{opacity:.9;max-width:550px;margin:0 auto 2.5rem;font-size:1.1rem;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}

/* Mid-page CTA */
.mid-cta{background:var(--cream);text-align:center;padding:4rem 0;position:relative}
.mid-cta h3{font-size:1.6rem;margin-bottom:.5rem}
.mid-cta p{color:var(--text-light);font-size:1.05rem;margin-bottom:1.5rem;max-width:500px;margin-left:auto;margin-right:auto;font-family:-apple-system,sans-serif}

/* Counter animation */
.counter-animated{display:inline-block}

/* Footer */
footer{background:var(--text);color:rgba(255,255,255,.6);padding:3.5rem 0;font-size:.85rem;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:2rem;margin-bottom:2rem}
.footer-brand{font-size:1.3rem;font-weight:700;color:rgba(255,255,255,.9);margin-bottom:.75rem;font-family:'Playfair Display',Georgia,serif}
.footer-brand span{color:var(--gold-light)}
footer p{margin-bottom:.4rem}
footer a{color:rgba(255,255,255,.8);transition:color .2s}
footer a:hover{color:var(--gold-light)}
footer h4{color:rgba(255,255,255,.9);font-size:.9rem;margin-bottom:.75rem;font-family:-apple-system,sans-serif}
footer ul{list-style:none}
footer ul li{margin-bottom:.4rem}
footer ul li a{transition:all .2s}
footer ul li a:hover{padding-left:.3rem}
.footer-bottom{border-top:1px solid rgba(255,255,255,.08);padding-top:1.5rem;text-align:center;font-size:.8rem}

/* Sticky mobile CTA */
.sticky-mobile-cta{display:none;position:fixed;bottom:0;left:0;right:0;z-index:99;background:var(--white);padding:.75rem 1rem;box-shadow:0 -4px 20px rgba(0,0,0,.1);border-top:1px solid rgba(0,0,0,.06)}
.sticky-mobile-cta .container{display:flex;gap:.75rem;align-items:center}
.sticky-mobile-cta .btn{flex:1;padding:.85rem .5rem;font-size:.9rem;text-align:center}
.sticky-mobile-cta .btn-call{background:var(--sage-dark);color:var(--white);border-radius:50px;font-weight:600;font-family:-apple-system,sans-serif;display:inline-block}

/* Exit intent modal */
.exit-modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:200;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.exit-modal-overlay.show{display:flex}
.exit-modal{background:var(--white);border-radius:20px;padding:3rem;max-width:480px;width:90%;text-align:center;position:relative;box-shadow:0 25px 80px rgba(0,0,0,.25);animation:modalIn .4s ease}
@keyframes modalIn{from{opacity:0;transform:scale(.9) translateY(20px)}to{opacity:1;transform:scale(1) translateY(0)}}
.exit-modal h3{font-size:1.6rem;margin-bottom:.75rem}
.exit-modal p{color:var(--text-light);margin-bottom:1.5rem;font-family:-apple-system,sans-serif}
.exit-modal .close-modal{position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--text-light);width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:background .2s}
.exit-modal .close-modal:hover{background:var(--cream)}

/* Scroll-triggered CTA */
.scroll-cta{display:none;position:fixed;bottom:5rem;right:1.5rem;z-index:90;background:linear-gradient(135deg,var(--cta),var(--cta-dark));color:var(--white);padding:.75rem 1.5rem;border-radius:50px;font-family:-apple-system,sans-serif;font-weight:600;font-size:.85rem;box-shadow:0 4px 20px rgba(212,118,58,.4);cursor:pointer;transition:all .3s;animation:slideUp .4s ease}
.scroll-cta:hover{transform:translateY(-3px) scale(1.03);box-shadow:0 8px 30px rgba(212,118,58,.55)}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

/* Chat placeholder */
.chat-widget{position:fixed;bottom:5.5rem;right:1.5rem;z-index:95;width:56px;height:56px;border-radius:50%;background:#25D366;color:var(--white);display:flex;align-items:center;justify-content:center;font-size:1.8rem;cursor:pointer;box-shadow:0 4px 20px rgba(37,211,102,.4);transition:all .3s;text-decoration:none}
.chat-widget:hover{transform:scale(1.12);box-shadow:0 8px 30px rgba(37,211,102,.5)}

/* Scroll progress indicator */
.scroll-progress{position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--gold),var(--cta),var(--gold));z-index:101;width:0%;transition:width .1s linear}

/* Mobile */
@media(max-width:768px){
  .top-bar{font-size:.75rem}
  .top-bar .container{justify-content:center;text-align:center}
  .top-bar-left{display:none}
  .nav-links{display:none;position:absolute;top:100%;left:0;right:0;background:var(--cream);flex-direction:column;padding:1.5rem;gap:1rem;border-bottom:1px solid rgba(0,0,0,.08);box-shadow:0 10px 30px rgba(0,0,0,.08)}
  .nav-links.open{display:flex}
  .nav-contact{display:none}
  .menu-toggle{display:block}
  .hero{min-height:auto;padding:6rem 0 4rem}
  .hero h1{font-size:clamp(2.2rem,7vw,3rem)}
  .hero-stats{gap:1rem}
  .about-inner{grid-template-columns:1fr;gap:2rem}
  .about-img{max-width:350px;margin:0 auto}
  .booking-grid{grid-template-columns:1fr;gap:2rem}
  .footer-grid{grid-template-columns:1fr;gap:1.5rem;text-align:center}
  section{padding:4rem 0}
  .outcomes{padding:3rem 0}
  .sticky-mobile-cta{display:block}
  .chat-widget{bottom:5rem}
  .scroll-cta{display:none!important}
  body{padding-bottom:70px}
  .icp-tabs{gap:.5rem}
  .icp-tab{font-size:.8rem;padding:.5rem 1rem}
  .divider-wave svg{height:30px}
  .section-title{font-size:clamp(1.8rem,5vw,2.4rem)}
}
@media(min-width:769px){
  .nav-contact{display:flex}
}
</style>
</head>
<body>

<!-- Scroll Progress -->
<div class="scroll-progress" id="scrollProgress"></div>

<!-- Nav -->
<nav id="mainNav">
<div class="container">
  <a href="#" class="logo">
    <img src="images/logo-full.png" alt="The Heart Shaman" class="logo-img-full">
  </a>
  <button class="menu-toggle" aria-label="Menu" onclick="document.querySelector('.nav-links').classList.toggle('open')">&#9776;</button>
  <ul class="nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#about">About Ryan</a></li>
    <li><a href="#testimonials">Reviews</a></li>
    <li><a href="#training">Training</a></li>
    <li><a href="#faq">FAQ</a></li>
    <li><a href="#gallery">Gallery</a></li>
    <li><a href="/blog/">Blog</a></li>
    <li><a href="#contact">Contact</a></li>
    <li><a href="https://ths.theproductspecialists.com/booking-5860" class="nav-cta" target="_blank" rel="noopener">Book Now</a></li>
  </ul>
  <div class="nav-contact">
    <a href="tel:07572120566">07572 120566</a>
    <a href="mailto:revive@theheartshaman.co.uk" style="font-size:.75rem;font-weight:400;color:var(--text-light)">revive@theheartshaman.co.uk</a>
  </div>
</div>
</nav>

<!-- Hero -->
<section class="hero">
<div class="hero-particles">
  <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
</div>
<div class="container">
  <div class="hero-badge">Shamanic Healing - Birmingham, UK</div>
  <div class="hero-stats">
    <span class="hero-stat"><strong class="counter" data-target="500" data-suffix="+">500+</strong>&nbsp;clients helped</span>
    <span class="hero-stat"><strong class="counter" data-target="174">174</strong>&nbsp;five-star reviews</span>
    <span class="hero-stat"><strong>10+ years</strong> experience</span>
  </div>
  <h1>Find Your Way Back <em>to Yourself</em></h1>
  <p class="hero-desc">Whether it is grief, burnout, patterns you cannot shake, or a feeling you cannot quite name - you can book directly, or start with a free 20-minute call if you are not sure where to begin.</p>
  <div class="hero-btns">
    <a href="https://ths.theproductspecialists.com/booking-5860" class="btn btn-primary btn-glow" target="_blank" rel="noopener">Book a Session</a>
    <a href="https://ths.theproductspecialists.com/booking-5860" class="btn btn-secondary" target="_blank" rel="noopener">Book a Free Discovery Call</a>
  </div>
  <p class="hero-note">Not sure which session is right for you? The free discovery call is the place to start.</p>
</div>
</section>

